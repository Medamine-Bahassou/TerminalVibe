{
  "name": "terminus",
  "version": "0.1.0",
  "private": true,
  "description": "Terminal multiplexer with browser proxy",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "tauri": "tauri",
    "dev": "GDK_BACKEND=x11 WEBKIT_DISABLE_COMPOSITING_MODE=1 npm run tauri dev",
    "build": "GDK_BACKEND=x11 WEBKIT_DISABLE_COMPOSITING_MODE=1 npm run tauri build"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-image": "^0.5.0",
    "xterm-addon-search": "^0.13.0",
    "xterm-addon-unicode11": "^0.6.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
