{
  "productName": "Terminus",
  "version": "0.1.0",
  "identifier": "com.terminus.app",
  "build": {
    "beforeDevCommand": "bash -c 'dir=$(dirname $(dirname $0)); mkdir -p $dir/dist/vendor/xterm && cp $dir/index.html $dir/app.js $dir/style.css $dir/logo.png $dir/dist/ && cp -r $dir/vendor/xterm/* $dir/dist/vendor/xterm/; while sleep 2; do cp $dir/index.html $dir/app.js $dir/style.css $dir/logo.png $dir/dist/ 2>/dev/null; done' bash",
    "beforeBuildCommand": "bash -c 'dir=$(dirname $(dirname $0)); mkdir -p $dir/dist/vendor/xterm && cp $dir/index.html $dir/app.js $dir/style.css $dir/logo.png $dir/dist/ && cp -r $dir/vendor/xterm/* $dir/dist/vendor/xterm/' bash",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Terminus",
        "width": 1200,
        "height": 684,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
